{
  "name": "code-search",
  "displayName": "Code Search",
  "description": "Full-text code search with SQLite FTS5 indexing and instant results",
  "version": "0.1.4",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/OscarKing888/CodeSearch.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeSearch.searchSelection",
    "onCommand:sourceSearch.searchSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "codeSearch",
          "title": "Code Search",
          "icon": "media/search.svg"
        }
      ]
    },
    "views": {
      "codeSearch": [
        {
          "type": "webview",
          "id": "codeSearch.panel",
          "name": "Search"
        }
      ]
    },
    "commands": [
      {
        "command": "codeSearch.searchSelection",
        "title": "Code Search: Search Selection or Word Under Cursor"
      },
      {
        "command": "codeSearch.focusSearch",
        "title": "Code Search: Focus Search Box"
      },
      {
        "command": "sourceSearch.searchSelection",
        "title": "Code Search: Search Selection (legacy alias)"
      },
      {
        "command": "sourceSearch.focusSearch",
        "title": "Code Search: Focus Search (legacy alias)"
      },
      {
        "command": "codeSearch.quickOpenFile",
        "title": "Code Search: Quick Open File"
      },
      {
        "command": "codeSearch.nextHit",
        "title": "Code Search: Next Hit"
      },
      {
        "command": "codeSearch.prevHit",
        "title": "Code Search: Previous Hit"
      },
      {
        "command": "codeSearch.refreshIndex",
        "title": "Code Search: Refresh Index"
      },
      {
        "command": "codeSearch.manageIndexes",
        "title": "Code Search: Manage Indexes"
      },
      {
        "command": "codeSearch.openSecondaryIndex",
        "title": "Code Search: Open Secondary Index"
      },
      {
        "command": "codeSearch.createIndex",
        "title": "Code Search: Create Index"
      },
      {
        "command": "codeSearch.searchInNewTab",
        "title": "Code Search: Search in New Tab"
      }
    ],
    "keybindings": [
      {
        "command": "codeSearch.searchSelection",
        "key": "alt+=",
        "when": "editorTextFocus || editorFocus"
      },
      {
        "command": "codeSearch.searchSelection",
        "key": "alt+equal",
        "when": "editorTextFocus || editorFocus"
      },
      {
        "command": "codeSearch.searchSelection",
        "key": "ctrl+alt+equal",
        "when": "editorTextFocus || editorFocus"
      },
      {
        "command": "codeSearch.focusSearch",
        "key": "shift+alt+=",
        "when": "editorTextFocus || editorFocus"
      },
      {
        "command": "codeSearch.focusSearch",
        "key": "shift+alt+equal",
        "when": "editorTextFocus || editorFocus"
      },
      {
        "command": "codeSearch.quickOpenFile",
        "key": "shift+alt+f"
      },
      {
        "command": "codeSearch.nextHit",
        "key": "f8",
        "when": "codeSearch.panel.focus"
      },
      {
        "command": "codeSearch.prevHit",
        "key": "shift+f8",
        "when": "codeSearch.panel.focus"
      }
    ],
    "configuration": {
      "title": "Code Search",
      "properties": {
        "codeSearch.excludeGlobs": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**",
            "**/out/**",
            "**/.vscode/**",
            "**/.cursor/**",
            "**/Intermediate/**",
            "**/Saved/**",
            "**/Binaries/**",
            "**/DerivedDataCache/**"
          ],
          "description": "Glob patterns to exclude from indexing (full path)"
        },
        "codeSearch.excludeDirNames": {
          "type": "array",
          "default": [
            ".git",
            "node_modules",
            "dist",
            "build",
            "bin",
            "obj",
            "out",
            ".vs",
            ".vscode",
            ".cursor",
            ".idea",
            "Intermediate",
            "Saved",
            "Binaries",
            "DerivedDataCache",
            "DerivedData"
          ],
          "description": "Directory segment names to exclude at any depth (supports wildcards)"
        },
        "codeSearch.excludeFileNames": {
          "type": "array",
          "default": [
            "*.pdb",
            "*.obj",
            "*.o",
            "*.exe",
            "*.dll",
            "*.so",
            "*.dylib",
            "*.cache",
            "*.min.js"
          ],
          "description": "File base names to exclude (supports wildcards)"
        },
        "codeSearch.includeGlobs": {
          "type": "array",
          "default": [
            "**/*"
          ],
          "description": "Glob patterns to include in indexing"
        },
        "codeSearch.contextLines": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 10,
          "description": "Number of context lines around each search hit"
        },
        "codeSearch.phraseSearchDefault": {
          "type": "boolean",
          "default": true,
          "description": "Treat multi-word queries as phrases by default"
        },
        "codeSearch.autoOpenSingleHit": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the file when there is only one hit"
        },
        "codeSearch.maxResults": {
          "type": "number",
          "default": 10000,
          "minimum": 100,
          "maximum": 100000,
          "description": "Maximum number of search results to return"
        },
        "codeSearch.indexOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically build index when a workspace is opened"
        },
        "codeSearch.maxFileSizeKB": {
          "type": "number",
          "default": 2048,
          "minimum": 64,
          "description": "Skip files larger than this size (KB)"
        },
        "codeSearch.fuzzySearchDefault": {
          "type": "boolean",
          "default": false,
          "description": "Enable fuzzy search by default (typo tolerance)"
        },
        "codeSearch.looseGapDefault": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 500,
          "description": "Default token gap for loose phrase search"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "rebuild:electron": "node scripts/rebuild-electron.js",
    "rebuild:electron:vscode": "node scripts/rebuild-electron.js vscode",
    "rebuild:electron:cursor": "node scripts/rebuild-electron.js cursor",
    "package": "vsce package",
    "test": "npx ts-node test/queryParser.test.ts && npx ts-node test/excludePatterns.test.ts",
    "cli": "node dist/cli.js"
  },
  "bin": {
    "ess": "./dist/cli.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  }
}
